VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key
VITE_ARCA_API_URL=http://localhost:3001
VITE_CONTA_CUIT=XX-XXXXXXXX-X

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ARCA homologacion by default. Use ARCA_ENV=production only with production certs.
ARCA_ENV=homologacion
ARCA_CUIT=your_cuit
ARCA_CERT_PATH=./certs/certificate.crt
ARCA_PRIVATE_KEY_PATH=./certs/private.key

# The points of sale must be enabled in ARCA for the matching web service.
ARCA_WSFE_PTO_VTA=1
ARCA_WSFEX_PTO_VTA=1

# Factura C receiver condition. 5 = Consumidor Final.
ARCA_DEFAULT_CONDICION_IVA_RECEPTOR_ID=5

# Factura E needs export destination data. Get the country code with FEXGetPARAM_DST_pais.
ARCA_EXPORT_DST_CMP=
ARCA_EXPORT_CLIENT_COUNTRY_CUIT=
ARCA_EXPORT_CLIENT_NAME=Cliente del exterior
ARCA_EXPORT_CLIENT_ADDRESS=Exterior
ARCA_EXPORT_CLIENT_TAX_ID=NO_DECLARADO
