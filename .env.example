VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key
VITE_ARCA_API_URL=http://localhost:3001
VITE_CONTA_CUIT=XX-XXXXXXXX-X
VITE_ARCA_ONBOARDING_URL=https://auth.afip.gob.ar/contribuyente_/login.xhtml
VITE_ARCA_MOCK_CSR=false
VITE_ARCA_MOCK_SAVE=false
ONBOARDING_VIDEO_FILE_PATH=

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:5173
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ARCA_ENCRYPTION_KEY=replace_with_a_long_random_master_key
ARCA_DISABLE_CSR_RATE_LIMIT=false

# ARCA homologacion by default. User CUIT/cert/key/points of sale live in user_arca_credentials.
ARCA_ENV=homologacion
ARCA_CMS_DIGEST=sha256
ARCA_CACHE_DIR=.arca-cache
ARCA_REQUEST_TIMEOUT_MS=15000
ARCA_HISTORICAL_PAGE_SIZE=100
ARCA_HISTORICAL_MAX_INVOICES_PER_QUERY=500

# Factura C receiver condition. 5 = Consumidor Final.
ARCA_DEFAULT_CONDICION_IVA_RECEPTOR_ID=5

# Factura E needs export destination data. Get the country code with FEXGetPARAM_DST_pais.
ARCA_EXPORT_DST_CMP=
ARCA_EXPORT_CLIENT_COUNTRY_CUIT=
ARCA_EXPORT_CLIENT_NAME=Cliente del exterior
ARCA_EXPORT_CLIENT_ADDRESS=Exterior
ARCA_EXPORT_CLIENT_TAX_ID=NO_DECLARADO

# Supabase Edge Function claude-chat
ALLOWED_ORIGIN=http://localhost:5173
